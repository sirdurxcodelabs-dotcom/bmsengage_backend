# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Configuration (SMTP)
# For Gmail: Use App Password (not regular password)
# Enable 2FA and generate App Password at: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME=Your Company Name

# Token encryption key (used to encrypt stored OAuth tokens)
TOKEN_ENCRYPTION_KEY=change_this_to_a_long_random_secret_32chars

# Meta / Facebook OAuth
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:5000/api/social/callback/meta

# Twitter/X OAuth 2.0 (PKCE)
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_CALLBACK_URL=http://localhost:5000/api/social/callback/twitter

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_id
LINKEDIN_CLIENT_SECRET=your_linkedin_secret
LINKEDIN_CALLBACK_URL=http://localhost:5000/api/social/callback/linkedin

# TikTok OAuth
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:5000/api/social/callback/tiktok

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ─────────────────────────────────────────────────────────────────────────────
# AI Caption Generation
# At least one key is recommended. If neither is set, the free HuggingFace
# public inference API is used (rate-limited, no key required).
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — get your key at https://platform.openai.com/api-keys
# Used for GPT-3.5-turbo caption generation (best quality)
OPENAI_API_KEY=sk-...your_openai_key_here

# HuggingFace — get your key at https://huggingface.co/settings/tokens
# Used for Mistral / Zephyr caption generation (free tier available)
# Create a READ token — no billing required for inference API
HUGGINGFACE_API_KEY=hf_...your_huggingface_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Twilio — for WhatsApp & SMS sharing (optional)
# Get credentials at https://console.twilio.com
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_FROM=+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary — for media asset storage
# Get credentials at https://cloudinary.com/console
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
